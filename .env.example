# Copier en .env.local / .env.staging / .env.production — ne jamais commiter le fichier réel

NODE_ENV=local
PORT=4000

# Local : Docker Compose (infra/docker/docker-compose.yml). Staging/Prod : MongoDB Atlas.
MONGO_URI=mongodb://localhost:27017/digitalesf_market

# Générer avec: openssl rand -base64 48
JWT_ACCESS_SECRET=change_me_min_16_chars
JWT_REFRESH_SECRET=change_me_min_16_chars_different

COOKIE_DOMAIN=localhost
CORS_ORIGIN=http://localhost:4200
